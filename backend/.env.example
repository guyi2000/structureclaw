# 环境配置示例文件
# 复制此文件为 .env 并填写实际值

# 服务配置
NODE_ENV=development
PORT=8000
HOST=0.0.0.0

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/structureclaw

# Redis 配置
# 可选。设为 disabled 表示不使用 Redis（自动降级为内存缓存）。
REDIS_URL=disabled

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# LLM Provider 配置（openai | zhipu | openai-compatible）
# 未配置 Key 时聊天接口会返回降级提示，但后端仍可启动。
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
LLM_TIMEOUT_MS=90000
LLM_MAX_RETRIES=0

# OpenAI 兼容保留字段（当 LLM_* 为空时可回退使用）
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_BASE_URL=https://api.openai.com/v1

# 智谱示例（LLM_PROVIDER=zhipu 时优先）
ZAI_API_KEY=
# Zhipu 默认模型与地址已内置：
# LLM_MODEL=glm-4-plus
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# 分析引擎配置
ANALYSIS_ENGINE_URL=http://localhost:8001

# CORS 配置
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# 日志配置
LOG_LEVEL=info
