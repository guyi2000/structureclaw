#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$SCRIPT_DIR"
CLI_VERSION="0.1.0"
HUB_SCRIPT="$ROOT_DIR/scripts/claw.sh"

print_help() {
  cat <<'EOF'
StructureClaw CLI

Usage:
  sclaw doctor
  sclaw start
  sclaw start-full
  sclaw stop
  sclaw status
  sclaw logs [frontend|backend|core|all] [--follow]
  sclaw install [--force]
  sclaw version
  sclaw help

Commands:
  doctor      Run startup checks without starting the full stack
  start       Start local stack (lite profile + uv)
  start-full  Start local stack with full core dependencies
  stop        Stop local stack and local infra
  status      Show process + health status
  logs        Show .runtime/logs output
  install     Install global `sclaw` command to ~/.local/bin
  version     Show CLI version
  help        Show this help
EOF
}

ensure_hub_script() {
  if [[ ! -x "$HUB_SCRIPT" ]]; then
    echo "Missing executable hub script: $HUB_SCRIPT"
    exit 1
  fi
}

install_cli() {
  local force=0
  if [[ "${1:-}" == "--force" ]]; then
    force=1
  elif [[ -n "${1:-}" ]]; then
    echo "Unknown option for install: $1"
    echo "Usage: sclaw install [--force]"
    exit 1
  fi

  local install_dir="$HOME/.local/bin"
  local target="$install_dir/sclaw"

  mkdir -p "$install_dir"

  if [[ -e "$target" && "$force" -ne 1 ]]; then
    echo "Target already exists: $target"
    echo "Use `sclaw install --force` to overwrite."
    exit 1
  fi

  ln -sf "$ROOT_DIR/sclaw" "$target"

  echo "Installed: $target -> $ROOT_DIR/sclaw"
  echo "If command is not found, add ~/.local/bin to your PATH."
}

cmd="${1:-help}"
case "$cmd" in
  doctor|start|start-full|stop|status)
    ensure_hub_script
    exec "$HUB_SCRIPT" "$cmd"
    ;;
  logs)
    ensure_hub_script
    exec "$HUB_SCRIPT" "$@"
    ;;
  install)
    install_cli "${2:-}"
    ;;
  version|-v|--version)
    echo "sclaw $CLI_VERSION"
    ;;
  help|-h|--help)
    print_help
    ;;
  *)
    echo "Unknown command: $cmd"
    echo
    print_help
    exit 1
    ;;
esac
