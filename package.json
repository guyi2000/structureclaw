{
  "name": "@structureclaw/structureclaw",
  "version": "1.0.0",
  "description": "AI-assisted structural engineering workspace",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "os": ["win32", "darwin", "linux"],
  "bin": {
    "sclaw": "./bin/sclaw.js",
    "sclaw_cn": "./bin/sclaw_cn.js"
  },
  "files": [
    "bin/",
    "dist/backend/",
    "!dist/backend/**/*.map",
    "!dist/backend/**/*.d.ts",
    "dist/frontend/",
    "scripts/cli/",
    "scripts/postinstall.js",
    "scripts/prepare-package.js",
    "backend/package.json",
    "backend/prisma/",
    "backend/scripts/",
    "backend/src/agent-skills/",
    "backend/src/skill-shared/python/",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npm run build --prefix backend",
    "build:frontend": "cd frontend && npm run build",
    "prepublishOnly": "node scripts/prepare-package.js",
    "postinstall": "node scripts/postinstall.js",
    "test:skills": "npm run test:skills --prefix backend",
    "test:skill:beam": "npm run test:skill:beam --prefix backend",
    "test:skill:frame": "npm run test:skill:frame --prefix backend",
    "test:skill:portal-frame": "npm run test:skill:portal-frame --prefix backend",
    "test:llm": "node tests/runner.mjs llm-integration",
    "test:llm:beam": "node tests/runner.mjs llm-integration --skill beam",
    "test:llm:frame": "node tests/runner.mjs llm-integration --skill frame",
    "test:llm:portal-frame": "node tests/runner.mjs llm-integration --skill portal-frame",
    "regression:backend": "node tests/runner.mjs backend-regression",
    "regression:analysis": "node tests/runner.mjs analysis-regression",
    "smoke:native": "node tests/runner.mjs smoke-native",
    "smoke:docker": "node tests/runner.mjs smoke-docker"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@langchain/core": "^1.1.40",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/openai": "^1.4.4",
    "@prisma/client": "^6.19.2",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.2",
    "yaml": "^2.8.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "optionalDependencies": {
    "pg": "^8.20.0"
  }
}
